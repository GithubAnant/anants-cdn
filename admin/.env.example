# Admin login (pick a strong password)
ADMIN_PASSWORD=change-me

# GitHub fine-grained PAT: Contents read/write on GithubAnant/anants-cdn
GITHUB_TOKEN=
GITHUB_OWNER=GithubAnant
GITHUB_REPO=anants-cdn
GITHUB_BRANCH=main

# Public CDN base (no trailing slash, no @version)
CDN_BASE_URL=https://cdn.anants.studio
